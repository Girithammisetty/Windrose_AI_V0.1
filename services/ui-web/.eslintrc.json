{
  "extends": ["next/core-web-vitals", "next/typescript"],
  "rules": {
    "@typescript-eslint/no-explicit-any": "off",
    "@typescript-eslint/no-unused-vars": ["error", { "argsIgnorePattern": "^_", "varsIgnorePattern": "^_" }],
    "no-restricted-syntax": [
      "error",
      {
        "selector": "CallExpression[callee.name='setInterval']",
        "message": "UI-FR-012: setInterval polling is banned. Use SSE via the EventBridge to patch TanStack Query caches."
      },
      {
        "selector": "CallExpression[callee.name='setTimeout'][arguments.length>0] > .callee[name='refetch']",
        "message": "UI-FR-012: timer-driven refetch loops are banned. Use SSE."
      }
    ]
  },
  "ignorePatterns": ["node_modules", ".next", "tests-e2e", "src/lib/graphql/generated.ts"]
}
