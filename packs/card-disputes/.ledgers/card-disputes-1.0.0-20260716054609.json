  "deferred": [
    {
      "kind": "guardrails",
      "reason": "Dispute-domain policies (no outcome promised to a cardholder before the human determination; denial letters must cite actual investigation findings; no provisional-credit reversal without the Reg E notice; UDAAP pattern-of-denial watch) require guardrail-service / OPA policy materialization, which Core does not expose as a pack surface yet. The behavioral core is partially covered today by Core invariants: every pack-configured agent is proposal-mode with four-eyes approval (agent-runtime), and the agent instructions + disposition taxonomy route final determinations exclusively to human analysts with the Dispute Operations Manager as approver."
    },
    {
      "kind": "agent_recipes",
      "reason": "Bespoke LangGraph recipes (Dispute Intake Copilot, Chargeback Representment Builder, First-Party Fraud Scorer, Provisional Credit Clock Sentinel) require agent-runtime graph-module registration (BRD 23 BR-12). This pack specializes the existing case-triage + analytics agents via TenantAgentConfig prompt_params + tenant-scope RAG grounding instead."
    },
    {
      "kind": "connection_templates",
      "reason": "Production read connectors (core processors: FIS/Fiserv/TSYS/Marqeta/ Galileo; network dispute rails: Visa Resolve Online (VROL), Mastercom; fraud platforms; ATM operator journals; carrier tracking APIs for delivery-confirmation evidence) require customer credentials and pack-service connector materialization. The pack ships seed datasets in the exact landing shape; production connectors are configured through the product Data > Connections UI."
    },
    {
      "kind": "write_adapters",
      "reason": "Write adapters (post/reverse provisional credit on the core, submit chargeback/representment via VROL/Mastercom, order card reissue, send Reg E/Z status and resolution letters) execute only behind pack-service's materialization contract and customer credentials; every such write stays proposal-mode with human approval \u2014 no autonomous credit movement or network filing, ever."
    },
    {
      "kind": "eval_sets",
      "reason": "Golden eval sets (dispute triage, deadline-risk ranking, chargeback reason-code selection, first-party fraud escalation) require eval-service write APIs whose action names are not yet in the rbac canonical catalog (Core follow-up noted in rbac catalog.go)."
    },
    {
      "kind": "ontology",
      "reason": "Ontology registration (Cardholder, Account, Card, Transaction, Dispute, Chargeback, Representment, ProvisionalCredit, Merchant, ReasonCode, DeadlineClock, ResolutionLetter) awaits pack-service; entity semantics are carried today by the disputes_core semantic model and dataset schemas."
    },
    {
      "kind": "case_schemas",
      "reason": "Typed case schemas (dispute_intake, fraud_investigation, chargeback_representment, atm_error_review, first_party_fraud_review) await case-service schema materialization; today's cases carry the same fields via display_projection + the disposition taxonomy."
    },
    {
      "kind": "model_archetypes",
      "reason": "Model archetypes (dispute_outcome_confidence, first_party_fraud_score) await experiment-service archetype APIs; the scoring capability ships as pipeline seeds instead (isolation_forest transaction anomaly + xgboost dispute-outcome scorer) with model-governance expectations noted in grounding memories."
    },
    {
      "kind": "display_labels",
      "reason": "Display-label overlays (\"Dispute\", \"Chargeback\", \"Provisional credit due\", \"Deadline at risk\", entity templates) require the BFF label-registry endpoints (BFF-FR-082/088) which are pack-service-tier features."
    }
  ],
