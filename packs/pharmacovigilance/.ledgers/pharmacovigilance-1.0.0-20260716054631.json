  "deferred": [
    {
      "kind": "guardrails",
      "reason": "PV-domain policies (no autonomous regulatory submission; conservative seriousness/expectedness when arguable; patient-identifier minimization in analyst-facing surfaces; late-case escalation) require guardrail-service / OPA policy materialization, which Core does not expose as a pack surface yet. The behavioral core is partially covered today by Core invariants: every pack-configured agent is proposal-mode with four-eyes approval (agent-runtime), and the agent instructions + disposition taxonomy route submission decisions exclusively to the Safety Officer (QPPV-equivalent)."
    },
    {
      "kind": "agent_recipes",
      "reason": "Bespoke LangGraph recipes (Intake Validity Checker, Duplicate Detector, MedDRA Coding Assistant, Narrative Drafter, Signal Evaluation Copilot) require agent-runtime graph-module registration (BRD 23 BR-12). This pack specializes the existing case-triage + analytics agents via TenantAgentConfig prompt_params + tenant-scope RAG grounding instead."
    },
    {
      "kind": "connection_templates",
      "reason": "Production read connectors (safety databases: Oracle Argus, ArisGlobal LifeSphere, Veeva Vault Safety; intake channels: call center, medical information, E2B(R3) gateways, literature monitoring services; MedDRA dictionary subscription) require customer credentials and pack-service connector materialization. The pack ships seed datasets in the exact landing shape; production connectors are configured through the product Data > Connections UI."
    },
    {
      "kind": "write_adapters",
      "reason": "Write adapters (E2B(R3) submission to FDA FAERS and EudraVigilance, case status write-back to the safety database, follow-up letter dispatch) execute only behind pack-service's materialization contract and customer gateway credentials; every such write stays proposal-mode with Safety Officer approval \u2014 no autonomous regulatory submission, ever."
    },
    {
      "kind": "eval_sets",
      "reason": "Golden eval sets (validity determination, seriousness classification, expectedness vs RSI, duplicate detection, expedited-vs-periodic routing) require eval-service write APIs whose action names are not yet in the rbac canonical catalog (Core follow-up noted in rbac catalog.go)."
    },
    {
      "kind": "ontology",
      "reason": "Ontology registration (Case/ICSR, AdverseEvent, Product, ActiveSubstance, Reporter, Patient, RegulatoryClock, ExpeditedReport, PeriodicReport, Signal, RSIVersion) awaits pack-service; entity semantics are carried today by the pv_core semantic model and dataset schemas."
    },
    {
      "kind": "case_schemas",
      "reason": "Typed case schemas (icsr_intake, medical_review, duplicate_review, signal_evaluation, late_case_investigation) await case-service schema materialization; today's cases carry the same fields via display_projection + the disposition taxonomy."
    },
    {
      "kind": "model_archetypes",
      "reason": "Model archetypes (case_priority_score, seriousness_classifier_v1) await experiment-service archetype APIs; the scoring capability ships as pipeline seeds instead (isolation_forest event anomaly + xgboost case-priority scorer) with GxP model-documentation expectations noted in grounding memories."
    },
    {
      "kind": "display_labels",
      "reason": "Display-label overlays (\"ICSR\", \"SUSAR\", \"15-day clock\", \"Signal cluster\", entity templates) require the BFF label-registry endpoints (BFF-FR-082/088) which are pack-service-tier features."
    }
  ],
