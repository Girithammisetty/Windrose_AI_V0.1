# =============================================================================
# Windrose — AWS Terraform example variables.
# Copy to terraform.tfvars (git-ignored) and fill in the placeholders.
# NEVER commit real secret values. In CI, pass secrets via TF_VAR_secrets.
# =============================================================================

# --- Core / naming ---------------------------------------------------------
region      = "us-east-1"      # fill in later: target AWS region
name_prefix = "windrose"       # fill in later: short prefix for all resources
environment = "prod"           # dev | staging | prod (tagging only)

# --- Networking ------------------------------------------------------------
vpc_cidr           = "10.60.0.0/16"
az_count           = 3
single_nat_gateway = false     # false = one NAT per AZ (production HA)

# --- EKS -------------------------------------------------------------------
eks_version                 = "1.30"
node_instance_types         = ["m6i.xlarge"]
node_capacity_type          = "ON_DEMAND"
node_min_size               = 3
node_max_size               = 8
node_desired_size           = 4
node_disk_size              = 100
cluster_public_access       = true
cluster_public_access_cidrs = ["0.0.0.0/0"]   # fill in later: lock to your office/VPN CIDRs

# --- RDS PostgreSQL --------------------------------------------------------
db_engine_version        = "16.4"
db_instance_class        = "db.m6g.large"
db_allocated_storage     = 100
db_max_allocated_storage = 500
db_multi_az              = true
db_admin_username        = "windrose_admin"   # password is generated by Terraform
db_backup_retention_days = 7
db_deletion_protection   = true

# --- ElastiCache (Redis/Valkey) --------------------------------------------
redis_node_type               = "cache.m6g.large"
redis_engine                  = "redis"        # or "valkey"
redis_engine_version          = "7.1"
redis_replicas_per_node_group = 1

# --- MSK (Kafka) -----------------------------------------------------------
kafka_version              = "3.6.0"
kafka_broker_count         = 3                 # multiple of az_count
kafka_broker_instance_type = "kafka.m5.large"
kafka_broker_ebs_size      = 100
kafka_sasl_username        = "windrose"        # password is generated by Terraform

# --- ECR (optional) --------------------------------------------------------
create_ecr = false             # true = one ECR repo per service

# --- IRSA / workload identity ----------------------------------------------
workload_namespace               = "windrose"
workload_service_account         = "windrose-workload"   # or "*" for all SAs in the namespace
external_secrets_namespace       = "external-secrets"
external_secrets_service_account = "external-secrets"

# --- Secrets (application-owned; FILL IN LATER) ----------------------------
# Infra creds (POSTGRES_ADMIN_PASSWORD, Redis auth, Kafka SASL password) are
# GENERATED by Terraform — do NOT put them here. Provide only app-owned creds.
# In CI prefer:  export TF_VAR_secrets='{"JWT_SIGNING_KEY_PEM":"...", ...}'
secrets = {
  # Per-service runtime DB role passwords (one NOBYPASSRLS role per DB):
  POSTGRES_APP_PASSWORD_IDENTITY     = "" # fill in later
  POSTGRES_APP_PASSWORD_RBAC         = "" # fill in later
  POSTGRES_APP_PASSWORD_INGESTION    = "" # fill in later
  POSTGRES_APP_PASSWORD_DATASET      = "" # fill in later
  POSTGRES_APP_PASSWORD_REALTIMEHUB  = "" # fill in later
  POSTGRES_APP_PASSWORD_AGENT_RUNTIME = "" # fill in later
  POSTGRES_APP_PASSWORD_MEMORY       = "" # fill in later
  POSTGRES_APP_PASSWORD_CASE_SVC     = "" # fill in later
  POSTGRES_APP_PASSWORD_TOOL_PLANE   = "" # fill in later
  POSTGRES_APP_PASSWORD_AI_GATEWAY   = "" # fill in later
  POSTGRES_APP_PASSWORD_PIPELINE     = "" # fill in later
  POSTGRES_APP_PASSWORD_EXPERIMENT   = "" # fill in later
  POSTGRES_APP_PASSWORD_INFERENCE    = "" # fill in later
  POSTGRES_APP_PASSWORD_QUERY        = "" # fill in later
  POSTGRES_APP_PASSWORD_SEMANTIC     = "" # fill in later
  POSTGRES_APP_PASSWORD_CHART        = "" # fill in later
  POSTGRES_APP_PASSWORD_USAGE        = "" # fill in later
  POSTGRES_APP_PASSWORD_NOTIFICATION = "" # fill in later
  POSTGRES_APP_PASSWORD_EVAL         = "" # fill in later

  # JWT / OIDC:
  JWT_SIGNING_KEY_PEM = "" # fill in later (RS256 private key PEM)
  JWT_JWKS            = "" # fill in later (published JWKS JSON)

  # Keycloak provisioning (or point OIDC_ISSUER at your own IdP):
  KEYCLOAK_ADMIN_USER     = "" # fill in later
  KEYCLOAK_ADMIN_PASSWORD = "" # fill in later

  # Vault (ingestion connector secrets) — or swap for the cloud secret store:
  VAULT_ADDR  = "" # fill in later
  VAULT_TOKEN = "" # fill in later

  # SMTP (notification-service):
  SMTP_HOST     = "" # fill in later
  SMTP_PORT     = "" # fill in later
  SMTP_USER     = "" # fill in later
  SMTP_PASSWORD = "" # fill in later

  # Optional LLM providers (omit to run Ollama-only / Bedrock via IRSA):
  OPENAI_API_KEY    = "" # fill in later (optional)
  ANTHROPIC_API_KEY = "" # fill in later (optional)

  # Analytics sink (audit + usage):
  CLICKHOUSE_URL      = "" # fill in later
  CLICKHOUSE_PASSWORD = "" # fill in later

  # Optional: static object-store keys ONLY if not using IRSA workload identity:
  # OBJECTSTORE_ACCESS_KEY = "" # fill in later (prefer IRSA instead)
  # OBJECTSTORE_SECRET_KEY = "" # fill in later (prefer IRSA instead)
}
