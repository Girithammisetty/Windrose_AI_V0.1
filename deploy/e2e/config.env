# Windrose e2e — shared config (sourced by run.sh). Ports are in the 83xx range
# to avoid every infra port (5432,6379,9092,8081,8180,7233,9000/1,8181,8281,8200,9200,4317/8,8233).
export PATH="/opt/homebrew/bin:$PATH"

# --- issuer / audience (identity-service hardcodes these; all services match) ---
export WR_ISS="https://identity.windrose.ai"
export WR_AUD="windrose"
export WR_JWKS_PORT="8300"
export WR_JWKS_URL="http://localhost:8300/jwks.json"

# --- service ports ---
export PORT_IDENTITY=8301
export PORT_RBAC=8302
export PORT_INGESTION=8303
export PORT_DATASET=8304
export PORT_REALTIME=8305
export PORT_REALTIME_INTERNAL=8315
export PORT_AGENT=8306
export PORT_MEMORY=8307
export PORT_CASE=8308
export PORT_TOOLREG=8310
export PORT_GATEWAY=8311
export PORT_AIGW=8312
# --- retrain-tail services ---
export PORT_PIPELINE=8313
export PORT_EXPERIMENT=8314
export PORT_INFERENCE=8316

# --- `make up` full-platform services (not booted by `make e2e`) ---
export PORT_QUERY=8085
export PORT_SEMANTIC=8086
export PORT_CHART=8320
export PORT_USAGE=8321
export PORT_AUDIT=8322
export PORT_NOTIFICATION=8323
export PORT_EVAL=8324
export PORT_BFF=4000
export PORT_UI=3000

# --- service base URLs ---
export IDENTITY_URL="http://localhost:${PORT_IDENTITY}"
export RBAC_URL="http://localhost:${PORT_RBAC}"
export INGESTION_URL="http://localhost:${PORT_INGESTION}"
export DATASET_URL="http://localhost:${PORT_DATASET}"
export REALTIME_URL="http://localhost:${PORT_REALTIME}"
export REALTIME_INTERNAL_URL="http://localhost:${PORT_REALTIME_INTERNAL}"
export AGENT_RUNTIME_URL="http://localhost:${PORT_AGENT}"
export MEMORY_URL="http://localhost:${PORT_MEMORY}"
export CASE_URL="http://localhost:${PORT_CASE}"
export TOOL_REGISTRY_URL="http://localhost:${PORT_TOOLREG}"
export MCP_GATEWAY_URL="http://localhost:${PORT_GATEWAY}"
export AI_GATEWAY_URL="http://localhost:${PORT_AIGW}"
export PIPELINE_URL="http://localhost:${PORT_PIPELINE}"
export EXPERIMENT_URL="http://localhost:${PORT_EXPERIMENT}"
export INFERENCE_URL="http://localhost:${PORT_INFERENCE}"
export QUERY_URL="http://localhost:${PORT_QUERY}"
export SEMANTIC_URL="http://localhost:${PORT_SEMANTIC}"
export CHART_URL="http://localhost:${PORT_CHART}"
export USAGE_URL="http://localhost:${PORT_USAGE}"
export AUDIT_URL="http://localhost:${PORT_AUDIT}"
export NOTIFICATION_URL="http://localhost:${PORT_NOTIFICATION}"
export EVAL_URL="http://localhost:${PORT_EVAL}"
export BFF_URL="http://localhost:${PORT_BFF}"
export UI_URL="http://localhost:${PORT_UI}"

# --- infra ---
export PGHOST=localhost PGPORT=5432 PGUSER=windrose PGPASSWORD=windrose_dev
export PG_BASE="postgres://windrose:windrose_dev@localhost:5432"
export PG_ASYNC_BASE="postgresql+asyncpg://windrose:windrose_dev@localhost:5432"
export PG_SYNC_BASE="postgresql+psycopg://windrose:windrose_dev@localhost:5432"
export REDIS_ADDR="localhost:6379"
export REDIS_URL="redis://localhost:6379/0"
export KAFKA_BROKERS="localhost:9092"
export SCHEMA_REGISTRY_URL="http://localhost:8081"
export OPA_URL="http://localhost:8281"
export OLLAMA_URL="http://localhost:11434"
export OLLAMA_V1="http://localhost:11434/v1"
export S3_ENDPOINT="http://localhost:9000"
export ICEBERG_URI="http://localhost:8181"
export OPENSEARCH_URL="http://localhost:9200"
export MLFLOW_URL="http://localhost:5500"
export VAULT_ADDR_="http://localhost:8200"
export VAULT_TOKEN_="windrose_dev_root"

# --- directories ---
export E2E_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
export REPO_DIR="$(cd "${E2E_DIR}/../.." && pwd)"
export LOG_DIR="${E2E_DIR}/logs"
export BIN_DIR="${E2E_DIR}/run/bin"
export PID_DIR="${E2E_DIR}/run/pids"
export PY="${E2E_DIR}/.venv/bin/python"
